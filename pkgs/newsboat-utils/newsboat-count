#!/usr/bin/env bash
# newsboat-count — output the number of unread Newsboat articles.
#
# Used by the Noctalia bar CustomButton widget (textCommand field).
# Prints "  <N>" when there are unread articles, or prints nothing (empty)
# when the count is 0 — noctalia hides the widget text when empty.
#
# Runs newsboat with -x print-unread which exits quickly without the TUI.

count=$(newsboat -x print-unread 2>/dev/null | awk '{print $1}')

# Validate: only print when count is a positive integer
if [ "${count}" -gt 0 ] 2>/dev/null; then
  printf '  %s' "$count"
fi
